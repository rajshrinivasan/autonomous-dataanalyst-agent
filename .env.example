# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use for agents (gpt-4o-mini is cheaper; gpt-4o is more capable)
OPENAI_MODEL=gpt-4o-mini

# FastAPI server
HOST=127.0.0.1
PORT=8000

# Paths
DB_PATH=data/sample.db
CHARTS_DIR=output/charts

# Postgres (Phase 0+)
POSTGRES_DSN=postgresql+asyncpg://analyst:analyst_dev@localhost:5432/analyst_db
POSTGRES_DSN_SYNC=postgresql://analyst:analyst_dev@localhost:5432/analyst_db

# Auth — Clerk JWT (Phase 2+)
JWT_JWKS_URL=https://clerk.your-domain.com/.well-known/jwks.json
JWT_AUDIENCE=your-clerk-app-id

# Docker sandbox (Phase 1+)
DOCKER_SANDBOX_IMAGE=ada-sandbox:latest

# Named connection secrets — one per datasource, referenced by connection_secret_ref
SECRET_SAMPLE_DB=sqlite:///./data/sample.db
