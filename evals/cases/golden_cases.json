{
  "cases": [
    {
      "id": "top_categories_revenue",
      "description": "Top 5 categories by revenue — most common business question",
      "question": "What are the top 5 product categories by total revenue?",
      "tags": ["revenue", "aggregation", "ranking"],
      "sql_checks": {
        "must_contain_tables": ["categories", "order_items"],
        "must_use_aggregation": true,
        "must_use_join": true,
        "must_use_group_by": true,
        "must_not_use_dml": true
      },
      "data_checks": {
        "expected_columns_subset": ["name"],
        "row_count_exact": 5,
        "first_row_contains": {"name": "Electronics"}
      },
      "analyst_checks": {
        "chart_required": true,
        "min_insights": 3,
        "insights_must_mention": ["Electronics", "%"]
      },
      "report_checks": {
        "required_sections": ["Executive Summary", "Key Findings", "Analysis", "Recommendations"],
        "must_mention_numbers": true,
        "max_words": 500
      }
    },
